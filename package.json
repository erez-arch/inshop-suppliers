{
  "name": "inshop-suppliers",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "DATABASE_URL=${DATABASE_URL:-file:./prisma/prod.db} prisma db push --skip-generate && DATABASE_URL=${DATABASE_URL:-file:./prisma/prod.db} tsx prisma/seed.ts && next start -p ${PORT:-3000}",
    "lint": "eslint src --ext .ts,.tsx",
    "seed": "tsx prisma/seed.ts",
    "db:push": "prisma db push",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.105.0",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^3.0.3",
    "iron-session": "^8.0.4",
    "multer": "^2.2.0",
    "next": "16.2.9",
    "prisma": "^5.22.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tsx": "^4.22.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
